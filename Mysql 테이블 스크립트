-- 친구신청 테이블 생성
CREATE TABLE REQUEST (   
    REQ_NO INT PRIMARY KEY,
    REQ_SENDER_NO INT NOT NULL,
    REQ_RECEIVER_NO INT NOT NULL,
    REQ_ILCHON_NICK VARCHAR(50),
    REQ_TITLE VARCHAR(100) NOT NULL,
    REQ_CONTENT VARCHAR(2000) NOT NULL, 
    REQ_DATE DATETIME NOT NULL DEFAULT NOW(),
    REQ_STATUS CHAR(1) DEFAULT 'H' CHECK (REQ_STATUS IN('Y', 'N', 'H'))
);

CALL create_sequence('SEQ_REQUEST');

ALTER TABLE REQUEST ADD CONSTRAINT FK_REQUEST_SENDER FOREIGN KEY(REQ_SENDER_NO) REFERENCES MEMBER(USER_NO);    
ALTER TABLE REQUEST ADD CONSTRAINT FK_REQUEST_RECEIVER FOREIGN KEY(REQ_RECEIVER_NO) REFERENCES MEMBER(USER_NO);


