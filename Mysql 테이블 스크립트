-- 일촌 테이블 생성
CREATE TABLE ILCHON (
    ILCHON_IDX INT PRIMARY KEY,
    USER_NO INT NOT NULL,
    ILCHON_NO INT NOT NULL,
    ILCHON_NICK VARCHAR(50),
    ILCHON_CATE CHAR(1) DEFAULT 'I' CHECK (ILCHON_CATE IN('I', 'C')),
    ILCHON_STATUS CHAR(1) DEFAULT 'Y' CHECK (ILCHON_STATUS IN('Y', 'N'))
);

CALL CREATE SEQUENCE('SEQ_ILCHON');

ALTER TABLE ILCHON ADD CONSTRAINT FK_ILCHON_USER_NO FOREIGN KEY(USER_NO) REFERENCES MEMBER(USER_NO);    
ALTER TABLE ILCHON ADD CONSTRAINT FK_ILCHON_ILCHON_NO FOREIGN KEY(ILCHON_NO) REFERENCES MEMBER(USER_NO);


