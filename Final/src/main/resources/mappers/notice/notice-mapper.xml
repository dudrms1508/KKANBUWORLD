<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="com.kh.world.notice.model.mapper.NoticeMapper">

	<sql id="noticeSql">
		SELECT NOTICE_NO,
				USER_NO,
				NOTICE_TITLE,
				NOTICE_CONTENT,
				NOTICE_DATE,
				NOTICE_VIEW,
				NOTICE_STATUS
		FROM NOTICE
	</sql>
	
	
	<resultMap id="noticeResultMap" type="NOTICE">
		<result property="no" column="NOTICE_NO"/>
		<result property="userNo" column="USER_NO"/>
		<result property="title" column="NOTICE_TITLE"/>
		<result property="content" column="NOTICE_CONTENT"/>
		<result property="date" column="NOTICE_DATE"/>
		<result property="view" column="NOTICE_VIEW"/>
		<result property="status" column="NOTICE_STATUS"/>
	</resultMap>
	
	<resultMap id="noticeRownumResultMap" type="NOTICE">
		<result property="no" column="NOTICE_NO"/>
		<result property="userNo" column="USER_NO"/>
		<result property="title" column="NOTICE_TITLE"/>
		<result property="content" column="NOTICE_CONTENT"/>
		<result property="date" column="NOTICE_DATE"/>
		<result property="view" column="NOTICE_VIEW"/>
		<result property="status" column="NOTICE_STATUS"/>
		<result property="rownum" column="NOTICE_ROWNUM"/>
	</resultMap>
	
	<resultMap id="memberResultMap" type="Member">
		<id property="no" column="USER_NO"/>
		
		<result property="id" column="USER_ID"/>
		<result property="password" column="USER_PWD"/>
		<result property="name" column="NAME"/>
		<result property="role" column="ROLE"/>
		<result property="phone" column="PHONE"/>
		<result property="email" column="EMAIL"/>
		<result property="birth" column="BIRTH"/>
		<result property="address" column="ADDRESS"/>
		<result property="searchMe" column="SEARCH_ME"/>
		<result property="gender" column="GENDER"/>
		<result property="minimi" column="MINIMI"/>
		<result property="createDate" column="CREATE_DATE"/>
		<result property="acorn" column="ACORN"/>
		<result property="status" column="STATUS"/>
	</resultMap>
	
	<select id="selectAll" resultMap="noticeResultMap">
		
		<include refid="noticeSql"/>
	</select>
	
	<select id="selectNoticeCount" parameterType="String" resultType="_int" >
		SELECT COUNT(*) 
		FROM NOTICE 
		WHERE NOTICE_STATUS = 'Y' 
		<if test="type != null">
			<choose>
				<when test='type.equals("T")'>
					AND NOTICE_TITLE LIKE concat('%',#{keyword},'%' )
				</when>
				<when test='type.equals("C")'>
					AND NOTICE_CONTENT LIKE concat('%',#{keyword},'%' )
				</when>
				<when test='type.equals("B")'>
					AND NOTICE_TITLE LIKE concat('%', #{keyword},'%' ) OR NOTICE_CONTENT LIKE concat('%', #{keyword},'%' )
				</when>
			</choose>
		</if>
	</select>

