		SELECT NOTICE_NO, USER_NO, NOTICE_TITLE, NOTICE_CONTENT, NOTICE_DATE, NOTICE_VIEW,NOTICE_STATUS
		FROM NOTICE
		WHERE NOTICE_STATUS = 'Y'
		ORDER BY NOTICE_NO DESC
	</select>
