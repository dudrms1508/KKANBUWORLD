	<select id="search" parameterType="map" resultMap="noticeRownumResultMap">
		SELECT NOTICE_NO, USER_NO, NOTICE_TITLE, NOTICE_CONTENT, NOTICE_DATE, NOTICE_VIEW,NOTICE_STATUS
		FROM NOTICE
		WHERE NOTICE_STATUS = 'Y' 
		<if test="type != null">
			<choose>
				<when test='type.equals("T")'>
					AND NOTICE_TITLE LIKE concat('%',#{keyword},'%' )
				</when>
				<when test='type.equals("C")'>
					AND NOTICE_CONTENT LIKE concat('%',#{keyword},'%' )
				</when>
				<when test='type.equals("B")'>
					AND NOTICE_TITLE LIKE concat('%', #{keyword},'%' ) OR NOTICE_CONTENT LIKE concat('%', #{keyword},'%' )
				</when>
			</choose>
			ORDER BY NOTICE_NO DESC
		</if>
	</select>
	
	
	<insert id="insertNotice" parameterType="map"
				useGeneratedKeys="true" keyColumn="NOTICE_NO" keyProperty="no">
		INSERT INTO NOTICE ( NOTICE_NO,
					USER_NO,
					NOTICE_TITLE,
					NOTICE_CONTENT,
					NOTICE_DATE,
					NOTICE_VIEW,
					NOTICE_STATUS)
			VALUES((SELECT NEXTVAL('notice_seq') FROM DUAL),
					#{loginMember.no},
					#{notice.title},
					#{notice.content},
					DEFAULT,
					DEFAULT,
					DEFAULT
					)
	</insert>
	
	<select id="isAdmin" parameterType="_int" resultType="_int">
		SELECT COUNT(*)
		FROM MEMBER 
		WHERE ROLE  ='Y' AND USER_NO = #{no}
	</select>
	
	
	<update id="updateNotice" parameterType="map">
		UPDATE 	NOTICE 
		SET		NOTICE_TITLE = #{notice.title}, NOTICE_CONTENT = #{notice.content}, NOTICE_DATE = DEFAULT 
		WHERE	NOTICE_NO = #{notice.no}
	</update>
	
	<select id="selectNoticeByNo" parameterType="_int" resultMap="noticeResultMap">
		SELECT 	*
		FROM 	NOTICE 
		WHERE 	NOTICE_NO = #{no}
		
	</select>
	
	<!-- no값을 받아서 해당하는 notice 가져다 줌 -->
	<select id="selectNoticeByRownum" parameterType="_int" resultMap="noticeRownumResultMap">
		SELECT NOTICE_ROWNUM, NOTICE_NO, NOTICE_TITLE, NOTICE_CONTENT, NOTICE_DATE
		FROM (SELECT ROW_NUMBER() OVER(ORDER BY NOTICE_NO DESC) NOTICE_ROWNUM,
						NOTICE_NO,
						NOTICE_TITLE,
						NOTICE_CONTENT,
						NOTICE_DATE
					FROM NOTICE
					WHERE NOTICE_STATUS = 'Y'
			) A
		WHERE NOTICE_NO = #{no}
	</select>
	
	
	<select id="selectNoticeRownum" parameterType="_int" resultMap="noticeRownumResultMap">
		SELECT NOTICE_ROWNUM, NOTICE_NO, NOTICE_TITLE, NOTICE_CONTENT, NOTICE_DATE
		FROM (SELECT ROW_NUMBER() OVER(ORDER BY NOTICE_NO DESC) NOTICE_ROWNUM,
						NOTICE_NO,
						NOTICE_TITLE,
						NOTICE_CONTENT,
						NOTICE_DATE
					FROM NOTICE
					WHERE NOTICE_STATUS = 'Y'
			) A
		WHERE NOTICE_ROWNUM = #{no}
	</select>
	
	
	<update id="deleteNotice">
		UPDATE NOTICE 
		SET NOTICE_STATUS ='N'
		WHERE  NOTICE_NO = #{no}
	</update>
	
	
</mapper>