<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="com.kh.world.member.model.mapper.MemberMapper">

	<sql id="selectMemberSql">
		SELECT USER_NO,
				USER_ID,
				USER_PWD,
				NAME,
				ROLE,
				PHONE,
				EMAIL,
				BIRTH,
				ADDRESS,
				SEARCH_ME,
				GENDER,
				MINIMI,
				CREATE_DATE,
				ACORN,
				STATUS
		FROM MEMBER 
	</sql>
	
	<resultMap id="memberResultMap" type="Member">
		<id property="no" column="USER_NO"/>
		
		<result property="id" column="USER_ID"/>
		<result property="password" column="USER_PWD"/>
		<result property="name" column="NAME"/>
		<result property="role" column="ROLE"/>
		<result property="phone" column="PHONE"/>
		<result property="email" column="EMAIL"/>
		<result property="birth" column="BIRTH"/>
		<result property="address" column="ADDRESS"/>
		<result property="searchMe" column="SEARCH_ME"/>
		<result property="gender" column="GENDER"/>
		<result property="minimi" column="MINIMI"/>
		<result property="createDate" column="CREATE_DATE"/>
		<result property="acorn" column="ACORN"/>
		<result property="status" column="STATUS"/>
	</resultMap>

	
	<select id="selectMemberById" parameterType="string" resultMap="memberResultMap">
	
		<include refid="selectMemberSql"/>
		
		WHERE USER_ID = #{id} AND STATUS='Y'
	</select>
	
	<select id="selectCount" resultType="_int">
		SELECT COUNT(*) FROM MEMBER
	</select>
	
	
	
	
</mapper>
