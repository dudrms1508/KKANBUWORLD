		${user_no},
		DEFAULT
		)	
</insert> -->
<update id="updateAcorn">
	UPDATE MEMBER SET ACORN = MEMBER.ACORN - ${product_money} WHERE USER_NO = ${user_no} 
</update>

<insert id="updateMyItem">
	INSERT INTO MyItem(USER_NO, PRODCUT_CODE)
	VALUES(
		${user_no},
		${product_code}
	)
</insert>

<select id="selectProductBgm" parameterType="string" resultMap="musicResultMap" >
	SELECT @rownum := @rownum + 1 as 'num' , (SUBSTRING_INDEX(PRODUCT_NAME, "-",1)) as 'name', (SUBSTRING_INDEX(PRODUCT_NAME,"-",-1)) as 'song_name', product_code 
	FROM PRODUCT
	WHERE CATEGORY_CODE  = 'BGM' AND (@rownum:=0) = 0	
</select>

<select id="selectAcorn" resultType="_int">
	SELECT ACORN
	FROM MEMBER
	WHERE USER_NO = ${user_no}
</select>

<select id="selectProductCount" resultType="_int">
	SELECT COUNT(*) FROM MyItem
	WHERE USER_NO = ${user_no} AND PRODCUT_CODE = ${product_code};
</select>

<select id="musicdetail" resultMap="productResultMap">
SELECT PRODUCT_CODE,
			CATEGORY_CODE,
			PRODUCT_NAME,
			PRODUCT_PRICE,
			PRODUCT_DATE,
			STATUS,
			PRODUCT_FILE,
			PRODUCT_URL
	FROM PRODUCT
	WHERE PRODUCT_CODE = ${product_code} 

</select>
 
</mapper>