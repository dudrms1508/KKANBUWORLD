		<result property="id" column="USER_ID"/>
		<result property="password" column="USER_PWD"/>
		<result property="name" column="NAME"/>
		<result property="role" column="ROLE"/>
		<result property="phone" column="PHONE"/>
		<result property="email" column="EMAIL"/>
		<result property="birth" column="BIRTH"/>
		<result property="address" column="ADDRESS"/>
		<result property="searchMe" column="SEARCH_ME"/>
		<result property="gender" column="GENDER"/>
		<result property="minimi" column="MINIMI"/>
		<result property="createDate" column="CREATE_DATE"/>
		<result property="acorn" column="ACORN"/>
		<result property="status" column="STATUS"/>
	</resultMap>
	
	<resultMap id="memberMinihomeResultmap" type="com.kh.world.minihome.model.vo.MemberMinihome">
		<id property="minihomeNo" column="MINIHOME_NO"/>
		<result property="profile" column="PROFILE"/>
		<result property="intro" column="INTRO"/>
		<result property="mood" column="MOOD"/>
		<result property="mbti" column="MBTI"/>
		<result property="miniroom" column="MINIROOM"/>
		<result property="theme" column="THEME"/>
		<result property="mhAccess" column="MH_ACCESS"/>
		<association property="DiaryReply" resultMap="DiaryReplyResultMap"/>
		<association property="member" javaType="Member" columnPrefix="M_"  
						resultMap="memberResultMap"/>
	</resultMap>
	
	<resultMap id="DiaryResultMap" type="Diary">
		<id property="dNo" column="D_NO" />
		<result property="minihomeNo" column="MINIHOME_NO" />
		<result property="dCate" column="D_CATE" />
		<result property="title" column="D_TITLE" />
		<result property="writer" column="D_WRITER_NO" />
		<result property="content" column="D_CONTENT" />
		<result property="oFile" column="D_ORIGIN" />
		<result property="rFile" column="D_RENAME" />
		<result property="url" column="D_URL" />
		<result property="createDate" column="D_CREATE_DATE" />
		<result property="modifyDate" column="D_MODIFY_DATE" />
		<result property="status" column="D_STATUS" />
		<result property="folder" column="D_FOLDER" />
		<association property="member" resultMap="memberResultMap"/>
	</resultMap>
	
	
	<resultMap id="DiaryReplyResultMap" type="DiaryReply">
		<id property="dreNo" column="DRE_NO" />
		<result property="dNo" column="D_NO" />
		<result property="writer" column="DRE_WRITER_NO" />
		<result property="content" column="DRE_CONTENT" />
		<result property="createDate" column="DRE_CREATE_DATE" />
		<result property="modifyDate" column="DRE_MODIFY_DATE" />
		<result property="secret" column="DRE_SECRET" />
		<result property="status" column="DRE_STATUS" />
		<result property="group" column="DRE_GROUP" />
		<result property="depth" column="DRE_DEPTH" />
		<result property="order" column="DRE_ORDER" />
		<association property="diary" resultMap="DiaryResultMap"/>
	</resultMap>
	
