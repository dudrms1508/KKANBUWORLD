	<insert id="insertDiary" parameterType="Diary"
				useGeneratedKeys="false" keyProperty="dNo" keyColumn="D_NO">
	   INSERT INTO DIARY (
	        MINIHOME_NO, 
	        D_CATE, 
	        D_WRITER_NO, 
	        D_TITLE, 
	        D_CONTENT, 
	        D_ORIGIN, 
	        D_RENAME, 
	        D_URL, 
	        D_CREATE_DATE, 
	        D_MODIFY_DATE, 
	        D_STATUS, 
	        D_FOLDER
	    ) 
	    VALUES (
	        #{minihomeNo}, 
	        DEFAULT, 
			#{writer},
	        #{title}, 
	        #{content}, 
	        'test오', 
	        'test', 
	        'test',
	        DEFAULT, 
	        DEFAULT, 
	        DEFAULT, 
	        DEFAULT
	    )
	</insert>

	<select id="findAllDiary" resultMap="DiaryResultMap">
		SELECT D_NO,
		       MINIHOME_NO,
		       D_CATE,
		       D_WRITER_NO,
		       D_TITLE,
		       D_CONTENT,
		       D_ORIGIN,
		       D_RENAME,
		       D_URL,
		       D_CREATE_DATE,
		       D_MODIFY_DATE,
		       D_STATUS,
		       D_FOLDER
		FROM DIARY
		WHERE MINIHOME_NO = #{minihomeNo} AND D_STATUS = 'Y' And D_WRITER_NO = #{writer}
		ORDER BY D_CREATE_DATE DESC
	</select>

	<!-- 게시글 수정 -->
	<update id="updateDiary" parameterType="Diary">
		UPDATE DIARY
		<trim prefix="SET" suffixOverrides=",">
			<if test="title != null">
				D_TITLE = #{title},
			</if>
			<if test="content != null">
				D_CONTENT = #{content},
			</if>
			D_MODIFY_DATE = NOW()
		</trim>
		WHERE D_NO = #{dNo}
	</update>
	
	
	<select id="findDiaryByNo" parameterType="_int" resultMap="DiaryResultMap">
		SELECT D.D_NO,
			   D.MINIHOME_NO, 
			   D.D_WRITER_NO, 
			   D.D_CATE,
			   D.D_TITLE, 
			   D.D_CONTENT, 
			   D.D_ORIGIN, 
			   D.D_RENAME, 
			   D.D_URL, 
			   D.D_CREATE_DATE, 
			   D.D_MODIFY_DATE, 
			   D.D_STATUS, 
			   D.D_FOLDER,
			   M.USER_ID AS M_USER_ID,
			   M.NAME AS M_NAME,
			   M.PHONE AS M_PHONE,
			   M.EMAIL AS M_EMAIL,
			   M.BIRTH AS M_BIRTH,
			   M.ADDRESS AS M_ADDRESS,
			   M.SEARCH_ME AS M_SEARCH_ME,
			   M.GENDER AS M_GENDER,
			   M.MINIMI AS M_MINIMI,
			   H.PROFILE,
			   H.INTRO,
			   H.MOOD,
			   H.MBTI,
			   H.MINIROOM,
			   H.THEME,
			   H.MH_ACCESS,
			   H.USER_NO AS H_USER_NO
		FROM DIARY D
		INNER JOIN MEMBER M ON D.D_WRITER_NO = M.USER_NO
		INNER JOIN MINIHOME H ON H.USER_NO = M.USER_NO
		WHERE D.D_NO = #{dNo} 
		AND D.D_STATUS = 'Y' 
		AND M.USER_NO = #{userNo}
	</select>
	
	<update id="deleteDiary">
		UPDATE DIARY
		SET
			D_STATUS = #{status}
		WHERE D_NO = #{dNo}
	</update>
	
	<insert id="insertDiaryReply" parameterType="DiaryReply"
				useGeneratedKeys="false" keyProperty="dreNo" keyColumn="DRE_NO">
		INSERT INTO DIARY_REPLY (
		    D_NO, 
		    DRE_WRITER_NO, 
		    DRE_CONTENT, 
		    DRE_CREATE_DATE, 
		    DRE_MODIFY_DATE, 
		    DRE_SECRET, 
		    DRE_STATUS, 
		    DRE_GROUP, 
		    DRE_DEPTH, 
		    DRE_ORDER
		) 
		VALUES (
		    #{dNo},
		    #{writer},
		    #{content},
		    DEFAULT, 
		    DEFAULT, 
		    DEFAULT, 
		    DEFAULT,
		    1, 
		    0, 
		    1
		)
	</insert>
	
