	 <select id="findReplyByNo" parameterType="_int" resultMap="DiaryReplyResultMap">
		SELECT  DRE_NO,
			    D_NO, 
			    DRE_WRITER_NO, 
			    DRE_CONTENT, 
			    DRE_CREATE_DATE, 
			    DRE_MODIFY_DATE, 
			    DRE_SECRET, 
			    DRE_STATUS, 
			    DRE_GROUP, 
			    DRE_DEPTH, 
			    DRE_ORDER
		FROM DIARY_REPLY R
		JOIN MEMBER M ON(R.DRE_WRITER_NO = M.USER_NO) 
		WHERE DRE_STATUS = 'Y'
		AND D_NO = #{dNo}
		ORDER BY DRE_NO DESC
		LIMIT 3
	</select>
	 
	

</mapper>

