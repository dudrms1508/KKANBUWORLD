<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="com.kh.world.diary.model.mapper.DiaryMapper">

	<sql id="selectDiarySql">
		 SELECT D_NO,
				MINIHOME_NO,
				D_CATE,
				D_WRITER_NO,
				D_TITLE,
				D_CONTENT,
				D_ORIGIN,
				D_RENAME,
				D_URL,
				D_CREATE_DATE,
				D_MODIFY_DATE,
				D_STATUS,
				D_FOLDER
		FROM DIARY 
	</sql>
	
	<sql id="selectMemberSql">
		 SELECT USER_NO,
				USER_ID,
				USER_PWD,
				NAME,
				ROLE,
				PHONE,
				EMAIL,
				BIRTH,
				ADDRESS,
				SEARCH_ME,
				GENDER,
				MINIMI,
				CREATE_DATE,
				ACORN,
				STATUS
		FROM MEMBER 
	</sql>
	
	<sql id="selectDiaryReplySql">
		 SELECT DRE_NO,
				D_NO,
				DRE_WRITER_NO,
				DRE_CONTENT,
				DRE_CREATE_DATE,
				DRE_MODIFY_DATE,
				DRE_SECRET,
				DRE_STATUS,
				DRE_GROUP,
				DRE_DEPTH,
				DRE_ORDER
		FROM DIARY_REPLY 
	</sql>
	
	
	<resultMap id="memberResultMap" type="Member">
