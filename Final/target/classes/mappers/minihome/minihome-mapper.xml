<insert id="insertilchonSay">
	INSERT INTO COMENT(C_NO, MINIHOME_NO, C_COMENT, CREATE_DATE, C_WRITENAME, C_WRITERNO) 
		VALUES
	((select nextval('COMMENT_SEQ') from dual), ${minihomeNo}, '${ilchonsay}', DEFAULT, '${user_name}', ${user_no})
</insert>

<select id="getCommentList" resultMap="comentResultMap">
	SELECT C_NO, C_COMENT,  DATE_FORMAT(CREATE_DATE, '%Y-%m-%d') AS CREATE_DATE
	 , C_WRITENAME, MINIHOME_NO , C_WRITERNO
	FROM COMENT
	WHERE MINIHOME_NO = #{minihomeNo};

</select>

<update id="updateilchonSay">
	UPDATE COMENT SET C_COMENT = '${content}'
	WHERE C_NO = ${cNo} AND C_WRITERNO = ${user_no}
</update>

<delete id="deleteilchonSay">
	DELETE FROM COMENT WHERE C_NO = ${cNo}
</delete>


