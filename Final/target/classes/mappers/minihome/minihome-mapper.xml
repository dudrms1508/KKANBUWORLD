	   <!-- 조회수 높은 사람 1등 -->
     <select id="findMinihomeCountRank1" resultMap="minihomeTotalResultMap">
        SELECT *
      FROM (
         SELECT H.MINIHOME_NO AS H_MINIHOME_NO,
               M.USER_NO AS M_USER_NO,
               M.USER_ID AS M_USER_ID,
                  M.NAME AS M_NAME,
                  M.STATUS AS M_STATUS,
                  H.PROFILE AS H_PROFILE,
                  H.INTRO AS H_INTRO,
                  T.T_COUNT AS T_COUNT,
                  ROW_NUMBER() over (ORDER BY T.T_COUNT DESC) AS T_RANK
         FROM MINIHOME H
         INNER JOIN MEMBER M ON (M.USER_NO = H.USER_NO)
         INNER JOIN MINIHOME_TOTAL T ON (T.MINIHOME_NO = H.MINIHOME_NO)
      ) HOMERANK
      WHERE HOMERANK.T_RANK = 1 AND HOMERANK.M_STATUS = 'Y'
   </select>
   
   	<!-- 조회수 높은 사람 2등 -->
	<select id="findMinihomeCountRank2" resultMap="minihomeTotalResultMap">
		SELECT *
		FROM (
			SELECT H.MINIHOME_NO AS H_MINIHOME_NO,
				   M.USER_NO AS M_USER_NO,
				   M.USER_ID AS M_USER_ID,
			   	   M.NAME AS M_NAME,
			   	   M.STATUS AS M_STATUS,
			   	   H.PROFILE AS H_PROFILE,
			   	   H.INTRO AS H_INTRO,
			   	   T.T_COUNT AS T_COUNT,
			   	   ROW_NUMBER() over (ORDER BY T.T_COUNT DESC) AS T_RANK
			FROM MINIHOME H
			INNER JOIN MEMBER M ON (M.USER_NO = H.USER_NO)
			INNER JOIN MINIHOME_TOTAL T ON (T.MINIHOME_NO = H.MINIHOME_NO)
		) HOMERANK
		WHERE HOMERANK.T_RANK = 2 AND HOMERANK.M_STATUS = 'Y'
	</select>
	
	<!-- 미니홈피 최근 게시글 -->
	<select id="findBoardNo" resultMap="boardListResultMap">
		SELECT B_NO,
			   B_TITLE
		FROM BOARD
		WHERE B_STATUS = 'Y'
		ORDER BY USER_NO = #{userNo} DESC LIMIT 1;
	</select>
	
	<!-- 미니홈피 최근 사진첩 -->
	<select id="findPhotoNo" resultMap="photoResultMap">
		SELECT PHOTO_NO,
			   PHOTO_TITLE
		FROM PHOTO
		WHERE PHOTO_STATUS = 'Y'
		ORDER BY MINIHOME_NO = #{minihomeNo} DESC LIMIT 1;
	</select>
	
	<!-- 미니홈피 최근 다이어리 -->
	<select id="findDiaryNo" resultMap="DiaryResultMap">
