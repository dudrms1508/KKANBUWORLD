<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="com.kh.world.charge.model.mapper.ChargeMapper">
	<resultMap type="PaymentVo" id="paymentResultMap">
		<id property="pay_idx" column="PAY_IDX"/>
		<result property="user_no" column="USER_NO"/>
		<result property="money" column="MONEY"/>
		<result property="cash_date" column="CASH_DATE"/>
		<result property="acorn_amount" column="ACONR_AMOUNT"/>
	</resultMap>
	
	<resultMap id="memberResultMap" type="Member">
		<id property="no" column="USER_NO"/>
		
		<result property="id" column="USER_ID"/>
		<result property="password" column="USER_PWD"/>
		<result property="name" column="NAME"/>
		<result property="role" column="ROLE"/>
		<result property="phone" column="PHONE"/>
		<result property="email" column="EMAIL"/>
		<result property="birth" column="BIRTH"/>
		<result property="address" column="ADDRESS"/>
		<result property="searchMe" column="SEARCH_ME"/>
		<result property="gender" column="GENDER"/>
		<result property="minimi" column="MINIMI"/>
		<result property="createDate" column="CREATE_DATE"/>
		<result property="acorn" column="ACORN"/>
		<result property="status" column="STATUS"/>
	</resultMap>
	
	<insert id="chargeInsert">
		INSERT INTO PAYMENT(PAY_IDX, USER_NO,MONEY,CASH_DATE, ACORN_AMOUNT)
		VALUES
		(
			(select nextval('payment_seq') from dual),
			${loginMember},
			${paymentvo.amount},
			DEFAULT,
			${paymentvo.goodsNm}
		)		
	</insert>
	
	<update id="chargeUpdate">
		UPDATE MEMBER SET ACORN = MEMBER.ACORN + ${paymentvo.goodsNm} WHERE USER_NO = ${loginMember}
	
	</update>
	
	
</mapper>